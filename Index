        <div className="flex-1 relative min-h-[300px]">
           <svg viewBox="0 0 800 300" className="w-full h-full overflow-visible">
             {/* Grid lines */}
             {[0, 60, 120, 180, 240, 300].map(y => (
                <line key={y} x1="0" y1={y} x2="800" y2={y} stroke="#f3f4f6" strokeWidth="1" />
