function AdminSalesTab({ orders }) {
  const totalSales = orders.reduce((sum, o) => sum + o.total, 0);
  const totalCost = orders.reduce((sum, order) => {
    return sum + order.items.reduce((itemSum, item) => itemSum + (item.cost * item.qty), 0);
  }, 0);
  const profit = totalSales - totalCost;

  return (
    <div className="space-y-6">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <DashboardKpi title="Total Revenue" value={`RM ${totalSales.toFixed(2)}`} icon={<BarChart2 className="text-indigo-500" />} />
        <DashboardKpi title="Total Cost" value={`RM ${totalCost.toFixed(2)}`} icon={<Package className="text-orange-500" />} />
        <DashboardKpi title="Net Profit" value={`RM ${profit.toFixed(2)}`} icon={<BarChart2 className="text-green-500" />} />
