function AdminCustomersTab({ orders }) {
  const customersMap = {};
  orders.forEach(o => {
    if(!customersMap[o.phone]) {
      customersMap[o.phone] = { name: o.customerName, phone: o.phone, spent: 0, orders: 0, lastOrder: o.timestamp };
    }
    customersMap[o.phone].spent += o.total;
    customersMap[o.phone].orders += 1;
    if(o.timestamp > customersMap[o.phone].lastOrder) customersMap[o.phone].lastOrder = o.timestamp;
  });
  const customersList = Object.values(customersMap);

  return (
    <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
       <div className="flex justify-between items-center mb-6">
          <h3 className="text-lg font-bold text-gray-900">Customer Database</h3>
