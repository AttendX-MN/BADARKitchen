import React, { useState, useEffect } from 'react';
import { 
  ShoppingBag, Search, Plus, Minus, Check, Clock, Bell, 
  Menu as MenuIcon, User, ChevronLeft, ChevronRight, 
  LayoutDashboard, ClipboardList, Settings, LogOut, 
  MoreVertical, Edit2, Trash2, Smartphone, Monitor, ChefHat,
  Users, BarChart2, Package, MessageCircle, X
} from 'lucide-react';

// === GOOGLE APPS SCRIPT DATABASE SETUP ===
// Paste the Web App URL from your Google Apps Script Deployment here:
const GAS_URL = 'https://script.google.com/macros/s/AKfycbwARKwsooKIRym-ECohyHJ73aieGdEh_aM_bFmJuGiOalCoAV7yRPZgs7ac4lAYH181/exec';

// --- MOCK DATA & CONFIG ---
const INITIAL_MENU = [
  { id: 'm1', name: 'Cheesy Beef Burger', desc: 'Burger daging dengan keju leleh, sos khas', price: 12.90, cost: 5.20, stock: 45, available: true, img: 'https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=300&q=80', category: 'Makanan' },
  { id: 'm2', name: 'Nasi Ayam Penyet', desc: 'Ayam penyet dengan sambal belacan dan ulam', price: 9.90, cost: 4.00, stock: 100, available: true, img: 'https://images.unsplash.com/photo-1626082927389-6cd097cdc6ec?auto=format&fit=crop&w=300&q=80', category: 'Makanan' },
  { id: 'm3', name: 'Spaghetti Carbonara', desc: 'Krim carbonara pekat dengan sosej', price: 11.90, cost: 4.50, stock: 30, available: true, img: 'https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9?auto=format&fit=crop&w=300&q=80', category: 'Makanan' },
  { id: 'm4', name: 'Air Milo Ais', desc: 'Milo ais kaw pekat melekat', price: 3.90, cost: 1.20, stock: 20, available: true, img: 'https://images.unsplash.com/photo-1541658016709-82535e94bc69?auto=format&fit=crop&w=300&q=80', category: 'Minuman' },
  { id: 'm5', name: 'Teh Ais Limau', desc: 'Teh O ais dengan perahan limau nipis', price: 2.50, cost: 0.80, stock: 50, available: true, img: 'https://images.unsplash.com/photo-1556679343-c7306c1976bc?auto=format&fit=crop&w=300&q=80', category: 'Minuman' }
];

const generateOrderId = () => `#A${Math.floor(100 + Math.random() * 900)}`;
const PRIMARY_COLOR = 'bg-indigo-600';
const TEXT_PRIMARY = 'text-indigo-600';

// --- MAIN APP COMPONENT ---
export default function App() {
  const [currentRole, setCurrentRole] = useState('customer'); 
  const [menu, setMenu] = useState([]); // Will load from DB
  const [orders, setOrders] = useState([]); // Will load from DB
  const [customerSessionOrder, setCustomerSessionOrder] = useState(null);
  const [isLoading, setIsLoading] = useState(true);

  // Fetch Database Data on Mount
  useEffect(() => {
    if (GAS_URL === 'YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL') {
      // Fallback: If you haven't put your URL in yet, load mock data for testing
      setMenu(INITIAL_MENU);
      setIsLoading(false);
      return;
    }

    fetch(`${GAS_URL}?action=getInitialData`)
      .then(res => res.json())
      .then(data => {
        if (data.menu) setMenu(data.menu);
        if (data.orders) {
          // Convert string timestamps back to Date objects
          setOrders(data.orders.map(o => ({...o, timestamp: new Date(o.timestamp)})));
        }
        setIsLoading(false);
      })
      .catch(err => {
        console.error("Failed to load Database", err);
        setMenu(INITIAL_MENU); // Fallback on failure
        setIsLoading(false);
      });
  }, []);

  const placeOrder = (customerDetails, cartItems, total) => {
    const newOrder = {
      id: generateOrderId(),
      customerName: customerDetails.name,
      phone: customerDetails.phone,
      items: cartItems,
      total,
      status: 'Pending',
      timestamp: new Date(),
    };
    
    // 1. Update UI Instantly (Optimistic update)
    setOrders(prev => [newOrder, ...prev]);
    setCustomerSessionOrder(newOrder);

    // 2. Save to Google Sheets Database
    if (GAS_URL !== 'YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL') {
      fetch(GAS_URL, {
        method: 'POST',
        body: JSON.stringify({ action: 'placeOrder', payload: newOrder }),
        headers: { 'Content-Type': 'text/plain;charset=utf-8' } // 'text/plain' prevents CORS preflight errors in GAS
      }).catch(err => console.error("Database save error:", err));
    }
  };

  const updateOrderStatus = (orderId, newStatus) => {
    // 1. Update UI Instantly
    setOrders(prev => prev.map(o => o.id === orderId ? { ...o, status: newStatus } : o));
    if (customerSessionOrder?.id === orderId) {
      setCustomerSessionOrder(prev => ({ ...prev, status: newStatus }));
    }

    // 2. Save to Google Sheets Database
    if (GAS_URL !== 'YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL') {
      fetch(GAS_URL, {
        method: 'POST',
        body: JSON.stringify({ action: 'updateOrderStatus', payload: { id: orderId, status: newStatus } }),
        headers: { 'Content-Type': 'text/plain;charset=utf-8' }
      }).catch(err => console.error("Database save error:", err));
    }
  };

  const toggleMenuItem = (id) => {
    // 1. Update UI Instantly
    setMenu(prev => prev.map(m => m.id === id ? { ...m, available: !m.available } : m));

    // 2. Save to Google Sheets Database
    if (GAS_URL !== 'YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL') {
      fetch(GAS_URL, {
        method: 'POST',
        body: JSON.stringify({ action: 'toggleMenuItem', payload: { id } }),
        headers: { 'Content-Type': 'text/plain;charset=utf-8' }
      }).catch(err => console.error("Database save error:", err));
    }
  };

  if (isLoading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-100 flex-col gap-4">
        <div className="w-12 h-12 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
        <p className="text-indigo-600 font-bold tracking-widest uppercase text-sm">Syncing Database...</p>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-100 font-sans text-gray-900 selection:bg-indigo-500 selection:text-white">
      {currentRole === 'customer' && <CustomerApp menu={menu} placeOrder={placeOrder} sessionOrder={customerSessionOrder} />}
      {currentRole === 'kitchen' && <KitchenApp orders={orders} updateOrderStatus={updateOrderStatus} menu={menu} toggleMenuItem={toggleMenuItem} />}
      {currentRole === 'admin' && <AdminApp orders={orders} menu={menu} />}

      {/* Floating Role Switcher Widget */}
      <div className="fixed bottom-6 right-6 z-[100] flex items-center bg-white rounded-full p-1.5 shadow-xl border border-gray-200">
        <button onClick={() => setCurrentRole('customer')} className={`p-2 rounded-full mx-1 transition-all flex items-center gap-2 ${currentRole === 'customer' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:bg-gray-100'}`}>
          <Smartphone size={18} />
          {currentRole === 'customer' && <span className="text-sm font-bold pr-2">Customer</span>}
        </button>
        <button onClick={() => setCurrentRole('kitchen')} className={`p-2 rounded-full mx-1 transition-all flex items-center gap-2 ${currentRole === 'kitchen' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:bg-gray-100'}`}>
          <ChefHat size={18} />
          {currentRole === 'kitchen' && <span className="text-sm font-bold pr-2">Kitchen</span>}
        </button>
        <button onClick={() => setCurrentRole('admin')} className={`p-2 rounded-full mx-1 transition-all flex items-center gap-2 ${currentRole === 'admin' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-500 hover:bg-gray-100'}`}>
          <Monitor size={18} />
          {currentRole === 'admin' && <span className="text-sm font-bold pr-2">Admin</span>}
        </button>
      </div>
    </div>
  );
}

// ==========================================
// 1. CUSTOMER INTERFACE (Mobile First Layout)
// ==========================================
function CustomerApp({ menu, placeOrder, sessionOrder }) {
  const [cart, setCart] = useState([]);
  const [view, setView] = useState('menu'); // menu, checkout, success, status
  const [customerForm, setCustomerForm] = useState({ name: '', phone: '' });
  const [showReadyPopup, setShowReadyPopup] = useState(false);

  // Sync view with session order
  useEffect(() => {
    if (sessionOrder && view === 'checkout') setView('success');
    if (sessionOrder?.status === 'Ready') setShowReadyPopup(true);
  }, [sessionOrder, view]);

  const activeMenu = menu.filter(item => item.available);
  
  const updateCart = (item, delta) => {
    setCart(prev => {
      const existing = prev.find(i => i.id === item.id);
      if (existing) {
        const newQty = existing.qty + delta;
        if (newQty <= 0) return prev.filter(i => i.id !== item.id);
        return prev.map(i => i.id === item.id ? { ...i, qty: newQty } : i);
      }
      if (delta > 0) return [...prev, { ...item, qty: 1 }];
      return prev;
    });
  };

  const getQty = (id) => cart.find(i => i.id === id)?.qty || 0;
  const cartTotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
  const cartCount = cart.reduce((sum, item) => sum + item.qty, 0);

  const handlePlaceOrder = (e) => {
    e.preventDefault();
    if (!customerForm.name || !customerForm.phone) return;
    placeOrder(customerForm, cart, cartTotal);
    setCart([]);
  };

  return (
    <div className="max-w-[400px] mx-auto bg-white min-h-screen shadow-2xl relative overflow-x-hidden sm:border-x border-gray-200 flex flex-col">
      
      {/* --- MENU VIEW --- */}
      {view === 'menu' && (
        <>
          <div className="px-5 pt-6 pb-2 sticky top-0 bg-white z-10">
            <div className="flex items-center justify-between mb-6">
              <MenuIcon className="text-gray-700" />
              <div className="text-center">
                <h1 className="text-xl font-bold text-gray-900 tracking-tight">BADAR</h1>
                <p className="text-[10px] text-gray-500 uppercase tracking-widest font-semibold -mt-1">Kitchen</p>
              </div>
              <div className="relative">
                <Bell className="text-gray-700" />
                <span className="absolute -top-1 -right-1 bg-red-500 w-2 h-2 rounded-full"></span>
              </div>
            </div>

            <h2 className="text-2xl font-extrabold text-gray-900 leading-tight">Makanan Sedap,<br/>Order Senang</h2>
            <p className="text-xs text-gray-500 mt-1 mb-4 flex items-center gap-1">
              Terima kasih atas sokongan anda! <span className="text-red-500">❤️</span>
            </p>

            <div className="relative mb-4">
              <Search size={18} className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" />
              <input type="text" placeholder="Cari makanan..." className="w-full bg-gray-100 text-sm rounded-full py-2.5 pl-10 pr-4 outline-none focus:ring-2 focus:ring-indigo-100" />
            </div>

            <div className="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
              {['Semua', 'Makanan', 'Minuman', 'Combo'].map((cat, i) => (
                <button key={cat} className={`px-4 py-1.5 rounded-full text-sm font-semibold whitespace-nowrap transition-colors ${i === 0 ? 'bg-indigo-600 text-white' : 'bg-white border border-gray-200 text-gray-600'}`}>
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <div className="flex-1 px-5 pb-24 overflow-y-auto">
            <h3 className="font-bold text-gray-800 mb-3 flex items-center gap-1">🔥 Popular</h3>
            <div className="space-y-4">
              {activeMenu.map(item => (
                <div key={item.id} className="bg-white rounded-2xl p-3 shadow-sm border border-gray-100 flex gap-4">
                  <img src={item.img} alt={item.name} className="w-20 h-20 object-cover rounded-xl shadow-sm" />
                  <div className="flex-1 flex flex-col justify-between py-0.5">
                    <div>
                      <h4 className="font-bold text-sm text-gray-900 leading-tight">{item.name}</h4>
                      <p className="text-[11px] text-gray-500 mt-0.5 line-clamp-2">{item.desc}</p>
                    </div>
                    <div className="flex items-center justify-between mt-2">
                      <span className="font-bold text-sm text-gray-900">RM {item.price.toFixed(2)}</span>
                      
                      {getQty(item.id) === 0 ? (
                        <button onClick={() => updateCart(item, 1)} className="bg-indigo-600 text-white w-6 h-6 flex items-center justify-center rounded hover:bg-indigo-700 active:scale-95 transition-all">
                          <Plus size={14} />
                        </button>
                      ) : (
                        <div className="flex items-center gap-3 border border-gray-200 rounded-lg p-0.5">
                          <button onClick={() => updateCart(item, -1)} className="p-1 active:scale-95 text-gray-600">
                            <Minus size={12} />
                          </button>
                          <span className="text-xs font-bold w-3 text-center">{getQty(item.id)}</span>
                          <button onClick={() => updateCart(item, 1)} className="p-1 active:scale-95 text-gray-600">
                            <Plus size={12} />
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {cartCount > 0 && (
            <div className="fixed bottom-0 left-0 right-0 max-w-[400px] mx-auto p-4 z-20 bg-white">
              <div className="bg-indigo-600 text-white rounded-2xl p-4 shadow-lg shadow-indigo-600/30 flex items-center justify-between cursor-pointer active:scale-[0.98] transition-transform"
                   onClick={() => setView('checkout')}>
                <div className="font-semibold text-sm">
                  {cartCount} Item • RM {cartTotal.toFixed(2)}
                </div>
                <div className="bg-white text-indigo-600 px-4 py-1.5 rounded-full text-sm font-bold">
                  Lihat Troli
                </div>
              </div>
            </div>
          )}
        </>
      )}

      {/* --- CHECKOUT VIEW --- */}
      {view === 'checkout' && (
        <div className="flex flex-col h-full bg-white">
          <div className="px-5 py-4 border-b border-gray-100 flex items-center gap-4">
            <button onClick={() => setView('menu')} className="text-gray-600"><ChevronLeft size={24} /></button>
            <h2 className="text-lg font-bold">Maklumat Anda</h2>
          </div>
          
          <div className="p-5 flex-1">
            <p className="text-sm text-gray-500 mb-6">Sila isi maklumat untuk membuat pesanan.</p>
            
            <form id="orderForm" onSubmit={handlePlaceOrder} className="space-y-5">
              <div>
                <label className="block text-xs font-semibold text-gray-700 mb-1.5">Nama Penuh</label>
                <input required type="text" value={customerForm.name} onChange={(e) => setCustomerForm({ ...customerForm, name: e.target.value })}
                  className="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-600 bg-gray-50"
                  placeholder="Ali Bin Ahmad" />
              </div>
              <div>
                <label className="block text-xs font-semibold text-gray-700 mb-1.5">Nombor Telefon</label>
                <input required type="tel" value={customerForm.phone} onChange={(e) => setCustomerForm({ ...customerForm, phone: e.target.value })}
                  className="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-600 bg-gray-50"
                  placeholder="012-345 6789" />
              </div>
            </form>
          </div>

          <div className="p-5">
            <button form="orderForm" type="submit" className="w-full bg-indigo-600 text-white rounded-xl py-3.5 font-bold shadow-lg shadow-indigo-600/30 active:scale-[0.98] transition-all">
              Buat Pesanan
            </button>
          </div>
        </div>
      )}

      {/* --- SUCCESS VIEW --- */}
      {view === 'success' && sessionOrder && (
        <div className="flex flex-col items-center justify-center h-full p-6 text-center animate-fade-in">
          <div className="bg-purple-100 p-4 rounded-full mb-6">
            <div className="bg-indigo-600 text-white p-3 rounded-full shadow-lg shadow-indigo-600/40">
              <Check size={32} />
            </div>
          </div>
          <h2 className="text-2xl font-bold text-gray-900 mb-2">Pesanan Dibuat!</h2>
          <p className="text-gray-500 text-sm mb-8">Terima kasih, pesanan anda telah diterima.</p>
          
          <div className="bg-gray-50 w-full rounded-2xl p-6 border border-gray-100 mb-8">
            <p className="text-xs text-gray-500 font-semibold mb-1 uppercase tracking-wider">Order Number</p>
            <div className="text-4xl font-black text-indigo-600 mb-2">{sessionOrder.id}</div>
            <p className="text-xs text-gray-400">Simpan nombor ini untuk semakan.</p>
          </div>

          <button onClick={() => setView('status')} className="w-full bg-indigo-600 text-white rounded-xl py-3.5 font-bold shadow-lg shadow-indigo-600/30 mb-4">
            Lihat Status Pesanan
          </button>
          
          <div className="flex items-center justify-center gap-2 text-gray-500 mb-8">
            <Clock size={16} />
            <span className="text-sm font-medium">Anggaran siap dalam <strong>15 - 20 minit</strong></span>
          </div>

          <button onClick={() => { setView('menu'); setCustomerSessionOrder(null); }} className="text-sm text-gray-500 font-semibold hover:text-gray-900">
            Kembali ke Menu
          </button>
        </div>
      )}

      {/* --- STATUS VIEW --- */}
      {view === 'status' && sessionOrder && (
        <div className="flex flex-col h-full bg-white">
          <div className="px-5 py-4 border-b border-gray-100 flex items-center gap-4">
            <button onClick={() => setView('success')} className="text-gray-600"><ChevronLeft size={24} /></button>
            <h2 className="text-lg font-bold">Status Pesanan</h2>
          </div>

          <div className="p-6">
            <h3 className="text-xl font-bold mb-1">Order {sessionOrder.id}</h3>
            <p className="text-sm text-gray-500 mb-8">Thank you, {sessionOrder.customerName}!</p>

            <div className="relative border-l border-gray-200 ml-4 space-y-8 pb-4">
              {[
                { state: 'Pending', label: 'Pesanan Diterima', time: sessionOrder.timestamp.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) },
                { state: 'Preparing', label: 'Sedang Disediakan', time: '10:35 AM' }, // Mock time
                { state: 'Ready', label: 'Makanan Dah Siap', time: 'Menunggu' },
                { state: 'Completed', label: 'Selesai', time: 'Menunggu' }
              ].map((step, idx) => {
                const statusSteps = ['Pending', 'Preparing', 'Ready', 'Completed'];
                const currentIdx = statusSteps.indexOf(sessionOrder.status);
                const isCompleted = currentIdx >= idx;
                const isCurrent = currentIdx === idx;
                
                return (
                  <div key={step.state} className="relative pl-6">
                    <div className={`absolute -left-[11px] top-0 w-5 h-5 rounded-full flex items-center justify-center ${isCompleted ? 'bg-indigo-600 text-white' : 'bg-white border-2 border-gray-200'}`}>
                      {isCompleted && <Check size={12} strokeWidth={4} />}
                    </div>
                    <div className="flex justify-between items-start -mt-0.5">
                      <h4 className={`text-sm font-bold ${isCompleted ? 'text-gray-900' : 'text-gray-400'}`}>{step.label}</h4>
                      <span className={`text-xs ${isCompleted ? 'text-gray-500' : 'text-gray-300'}`}>
                        {isCompleted && idx <= currentIdx ? new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : step.time}
                      </span>
                    </div>
                  </div>
                )
              })}
            </div>
            
            <p className="text-xs text-gray-400 text-center mt-12 bg-gray-50 p-3 rounded-lg">
              Kami akan maklumkan bila makanan anda siap!
            </p>
          </div>

          {/* Ready Popup Notification */}
          {showReadyPopup && (
            <div className="fixed inset-0 z-50 flex items-start justify-center bg-gray-900/40 p-4 backdrop-blur-sm">
              <div className="bg-white w-full max-w-[360px] rounded-2xl p-6 shadow-2xl mt-20 text-center relative animate-fade-in-up">
                <button onClick={() => setShowReadyPopup(false)} className="absolute top-3 right-3 text-gray-400 hover:text-gray-600"><X size={20} /></button>
                <div className="text-4xl mb-3">🎉</div>
                <h3 className="text-xl font-bold text-gray-900 mb-1">Makanan Dah Siap!!!</h3>
                <p className="text-gray-600 font-semibold mb-2">Order {sessionOrder.id} anda sudah siap.</p>
                <p className="text-sm text-gray-500 mb-6">Sila ambil makanan anda di kaunter. Terima kasih!</p>
                <button onClick={() => {setShowReadyPopup(false); setView('menu'); setCustomerSessionOrder(null);}} className="w-full bg-indigo-600 text-white rounded-xl py-3 font-bold">
                  Terima Kasih!
                </button>
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

