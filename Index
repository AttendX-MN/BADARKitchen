}

function KitchenOrderCard({ order, updateStatus }) {
  const timeStr = order.timestamp.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
  
  const statusConfig = {
    Pending: { color: 'orange', action: 'Pending', next: 'Preparing', topBorder: 'border-orange-400', bgBtn: 'bg-orange-500 hover:bg-orange-600', textID: 'text-orange-500' },
    Preparing: { color: 'blue', action: 'Preparing', next: 'Ready', topBorder: 'border-blue-400', bgBtn: 'bg-blue-500 hover:bg-blue-600', textID: 'text-blue-500' },
    Ready: { color: 'green', action: 'Ready', next: 'Completed', topBorder: 'border-green-400', bgBtn: 'bg-green-500 hover:bg-green-600', textID: 'text-green-500' }
  };
  const conf = statusConfig[order.status];

  return (
    <div className={`bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col overflow-hidden relative pt-1`}>
      <div className={`absolute top-0 left-0 right-0 h-1.5 ${conf.topBorder} border-t-4`}></div>
      <div className="p-5 flex-1">
        <div className="flex justify-between items-start mb-4">
          <h3 className={`text-xl font-black ${conf.textID}`}>{order.id}</h3>
          <span className="text-xs font-semibold text-gray-500">{timeStr}</span>
        </div>
        
        <div className="mb-4">
          <p className="font-bold text-gray-900 text-sm">{order.customerName}</p>
          <p className="text-xs text-gray-500">{order.phone}</p>
        </div>
        
        <ul className="space-y-2 mb-6">
          {order.items.map((item, idx) => (
            <li key={idx} className="flex gap-3 text-sm text-gray-700">
              <span className="font-bold text-gray-900 w-5">{item.qty}x</span>
              <span className="leading-tight">{item.name}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <div className="p-4 bg-gray-50 border-t border-gray-100">
        <button 
          onClick={() => updateStatus(order.id, conf.next)}
          className={`w-full py-2.5 rounded-lg font-bold text-white shadow-md active:scale-[0.98] transition-all flex items-center justify-center gap-2 ${conf.bgBtn}`}
        >
          {conf.action}
          {order.status === 'Ready' && <Check size={16} />}
        </button>
      </div>
    </div>
  );
}

