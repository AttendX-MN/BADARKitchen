                  <td className="py-4 font-bold text-green-600">RM {c.spent.toFixed(2)}</td>
                  <td className="py-4 text-gray-500">{c.lastOrder.toLocaleDateString()}</td>
                  <td className="py-4 text-right">
                     <button className="text-indigo-600 bg-indigo-50 px-3 py-1.5 rounded text-sm font-bold hover:bg-indigo-100 transition-colors">View Profile</button>
